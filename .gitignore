# IDE / Editor
.kiro
.claude
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary / working files
tmp/

# Internal Use Markdown Files
VALIDATE.md
WORKSHOP_VISION.md
PLAN*
eks-best-practices-workspace

# eks-upgrade-check skill outputs (per-run, not source)
EKS-Upgrade-Assessment-*.md
EKS-Upgrade-Assessment-*.html

# eks-operation-review skill outputs (per-run, not source)
EKS-Operation-Review-*.md
EKS-Operation-Review-*.html
reports/

# Eval artefacts (misc/evals/) — per-run ephemera. history/ is intentionally
# tracked so regression detection has shared signal across contributors.
misc/evals/*/workspace/
misc/evals/**/*.html
misc/evals/.secrets/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Terraform (if running examples locally)
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example

# Node (if any tooling uses it)
node_modules/

# Docusaurus (misc/website/) — generated wrappers + manifest are tracked,
# but local dev caches and build output are not.
misc/website/node_modules/
misc/website/.docusaurus/
misc/website/build/

# Logs
*.log
HISTORY.md
